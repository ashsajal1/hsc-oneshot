---
import 'katex/dist/katex.min.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1e293b" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <a href="/" class="home-link">HSC Oneshot</a>
      <button id="theme-toggle" aria-label="Toggle dark mode">
        <svg class="sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg class="moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </nav>
    <slot />
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      window.localStorage.setItem('theme', theme);
      const toggle = document.getElementById('theme-toggle');
      toggle?.addEventListener('click', () => {
        document.documentElement.classList.toggle('dark');
        const isDark = document.documentElement.classList.contains('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    </script>
    <style is:global>
      :root {
        --bg: #f9fafb;
        --bg-card: #fff;
        --bg-nav: #1e293b;
        --text: #111827;
        --text-secondary: #6b7280;
        --text-heading: #374151;
        --border: #e5e7eb;
        --border-strong: #d1d5db;
        --num-bg: #eff6ff;
        --num-text: #2563eb;
        --hover-bg: #e5e7eb;
        --th-bg: #f3f4f6;
        --nav-text: #fff;
        --nav-hover: #93c5fd;
      }
      .dark {
        --bg: #0f172a;
        --bg-card: #1e293b;
        --bg-nav: #020617;
        --text: #e2e8f0;
        --text-secondary: #94a3b8;
        --text-heading: #cbd5e1;
        --border: #334155;
        --border-strong: #475569;
        --num-bg: #1e3a5f;
        --num-text: #60a5fa;
        --hover-bg: #334155;
        --th-bg: #1e293b;
        --nav-text: #e2e8f0;
        --nav-hover: #60a5fa;
      }
      body {
        background: var(--bg);
        color: var(--text);
        transition: background 0.2s, color 0.2s;
      }
      nav {
        background: var(--bg-nav);
        padding: 0.75rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .home-link {
        color: var(--nav-text);
        text-decoration: none;
        font-weight: 700;
        font-size: 1rem;
      }
      .home-link:hover {
        color: var(--nav-hover);
      }
      #theme-toggle {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--nav-text);
        border-radius: 6px;
        transition: background 0.2s;
      }
      #theme-toggle:hover {
        background: rgba(255, 255, 255, 0.1);
      }
      #theme-toggle .sun { display: none; }
      #theme-toggle .moon { display: block; }
      .dark #theme-toggle .sun { display: block; }
      .dark #theme-toggle .moon { display: none; }
      table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
        font-size: 0.95rem;
      }
      th, td {
        border: 1px solid var(--border-strong);
        padding: 0.6rem 0.8rem;
        text-align: left;
      }
      th {
        background-color: var(--th-bg);
        font-weight: 600;
      }
      tr:nth-child(even) {
        background-color: var(--bg);
      }
      tr:hover {
        background-color: var(--hover-bg);
      }
      .katex-display {
        text-align: center;
        margin: 2rem 0;
      }
      .katex-display > .katex {
        font-size: 2.2em;
      }
      .katex {
        font-size: 1.5em;
      }
      blockquote {
        border-left: 4px solid var(--num-text);
        padding: 0.75rem 1rem;
        margin: 1rem 0;
        background: var(--bg-card);
        border-radius: 0 8px 8px 0;
      }
      code {
        background: var(--hover-bg);
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.9em;
      }
      pre {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1rem;
        overflow-x: auto;
      }
    </style>
  </body>
</html>
